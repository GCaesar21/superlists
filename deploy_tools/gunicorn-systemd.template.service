[Unit]
Description=Gunicorn server for SITENAME

[Service]
Restart=on-failure
User=webuser
WorkingDirectory=/home/webuser/sites/SITENAME/source
ExecStart=/home/webuser/sites/SITENAME/virtualenv/bin/gunicorn --bind unix:/tmp/SITENAME.socket superlists.wsgi:application


[Install]
WantedBy=multi-user.target
